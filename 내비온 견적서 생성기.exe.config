<?xml version="1.0" encoding="utf-8"?>
<!-- MOTW(다운로드 차단) 대응: 카카오톡/브라우저로 받은 ZIP을 풀면
     Zone.Identifier가 붙은 Python.Runtime.dll을 .NET Framework가 기본 거부함.
     loadFromRemoteSources로 인터넷 존 어셈블리를 전체 신뢰로 로드한다.
     배치 위치: EXE와 같은 최상위 폴더 (_internal 아님) — navion_quote.spec datas 참조. -->
<configuration>
  <runtime>
    <loadFromRemoteSources enabled="true"/>
  </runtime>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
  </startup>
</configuration>
